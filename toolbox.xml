<xml xmlns="https://developers.google.com/blockly/xml" id="toolbox" style="display: none">
  <category id="kbot" name="KBOT" colour="#ff7513" icon="camera">
    <label text="KBOT Robot" web-class="blockLabelStyle"></label>
    <block type="kbot_motor_init" />
    <block type="kbot_set_encoder">
      <value name="rpm">
        <shadow type="math_number">
          <field name="NUM">350</field>
        </shadow>
      </value>
      <value name="ppr">
        <shadow type="math_number">
          <field name="NUM">11</field>
        </shadow>
      </value>
      <value name="gears">
        <shadow type="math_number">
          <field name="NUM">34</field>
        </shadow>
      </value>
    </block>
    <block type="kbot_set_speed">
      <value name="speed">
        <shadow type="math_number">
          <field name="NUM">70</field>
        </shadow>
      </value>
    </block>
    <block type="kbot_move">
      <value name="speed">
        <shadow type="math_number">
          <field name="NUM">70</field>
        </shadow>
      </value>
    </block>
    <block type="kbot_move_for">
      <value name="speed">
        <shadow type="math_number">
          <field name="NUM">70</field>
        </shadow>
      </value>
      <value name="amount">
        <shadow type="math_number">
          <field name="NUM">2</field>
        </shadow>
      </value>
    </block>
    <block type="kbot_run_speed">
      <value name="left_speed">
        <shadow type="math_number">
          <field name="NUM">50</field>
        </shadow>
      </value>
      <value name="right_speed">
        <shadow type="math_number">
          <field name="NUM">50</field>
        </shadow>
      </value>
    </block>
    <block type="kbot_stop" />

    <sep gap="30"></sep>
    <label text="Gamepad" web-class="blockLabelStyle"></label>
    <block type="kbot_gamepad_init">
      <value name="accel_steps">
        <shadow type="math_number">
          <field name="NUM">3</field>
        </shadow>
      </value>
    </block>
    <block type="kbot_gamepad_on_button" />
    <block type="kbot_gamepad_read_button" />
    <block type="kbot_gamepad_read_joystick" />
    <block type="kbot_gamepad_pause" />

    <sep gap="30"></sep>
    <label text="Dò line" web-class="blockLabelStyle"></label>
    <block type="kbot_line_sensor_init" />
    <block type="kbot_line_sensor_read_all" />
    <block type="kbot_line_sensor_read" />
    <block type="kbot_follow_line_until_cross" />
    <block type="kbot_turn_until_line_detected" />
    <block type="kbot_follow_line_until_end" />
    <block type="kbot_follow_line_by_time">
      <value name="duration">
        <shadow type="math_number">
          <field name="NUM">1</field>
        </shadow>
      </value>
    </block>
    <block type="kbot_follow_line_until">
      <value name="condition"></value>
    </block>

    <sep gap="30"></sep>
    <label text="Xoay theo góc" web-class="blockLabelStyle"></label>
    <block type="kbot_gyro_init">
      <value name="samples">
        <shadow type="math_number">
          <field name="NUM">250</field>
        </shadow>
      </value>
    </block>
    <block type="kbot_turn_degree">
      <value name="speed">
        <shadow type="math_number">
          <field name="NUM">50</field>
        </shadow>
      </value>
      <value name="degree">
        <shadow type="math_number">
          <field name="NUM">90</field>
        </shadow>
      </value>
    </block>

    <sep gap="30"></sep>
    <label text="HuskyLens" web-class="blockLabelStyle"></label>
    <block type="huskylens_i2c_init" />
    <block type="huskylens_update_block" />
    <block type="huskylens_bounding_box" />
    <block type="huskylens_update_arrow" />
    <block type="huskylens_line_tracking" />

    <sep gap="30"></sep>
    <label text="Vision Tracking" web-class="blockLabelStyle"></label>
    <block type="kbot_track_set_pid">
      <value name="kp">
        <shadow type="math_number">
          <field name="NUM">0.23</field>
        </shadow>
      </value>
      <value name="ki">
        <shadow type="math_number">
          <field name="NUM">0</field>
        </shadow>
      </value>
      <value name="kd">
        <shadow type="math_number">
          <field name="NUM">0.4</field>
        </shadow>
      </value>
    </block>
    <block type="kbot_track_set_speed">
      <value name="min_speed">
        <shadow type="math_number">
          <field name="NUM">25</field>
        </shadow>
      </value>
      <value name="max_speed">
        <shadow type="math_number">
          <field name="NUM">80</field>
        </shadow>
      </value>
    </block>
    <block type="kbot_track_update">
      <value name="target">
        <shadow type="math_number">
          <field name="NUM">155</field>
        </shadow>
      </value>
    </block>
    <block type="kbot_track_speed" />

    <sep gap="30"></sep>
    <label text="PID Motor (RPM chính xác)" web-class="blockLabelStyle"></label>
    <block type="kbot_set_target_rpm">
      <value name="left_rpm">
        <shadow type="math_number">
          <field name="NUM">40</field>
        </shadow>
      </value>
      <value name="right_rpm">
        <shadow type="math_number">
          <field name="NUM">40</field>
        </shadow>
      </value>
    </block>
    <block type="kbot_pid_update">
      <value name="kp">
        <shadow type="math_number">
          <field name="NUM">1.5</field>
        </shadow>
      </value>
      <value name="ki">
        <shadow type="math_number">
          <field name="NUM">0.07</field>
        </shadow>
      </value>
      <value name="kd">
        <shadow type="math_number">
          <field name="NUM">0.5</field>
        </shadow>
      </value>
    </block>
    <block type="kbot_pid_stop" />
    <block type="kbot_pid_reset" />

    <sep gap="30"></sep>
    <label text="Test động cơ nhanh" web-class="blockLabelStyle"></label>
    <block type="kbot_motor_run">
      <value name="speed">
        <shadow type="math_number">
          <field name="NUM">70</field>
        </shadow>
      </value>
    </block>
  </category>
  <category id="robotics" name="ROBOTICS" colour="#717171" icon="robot">
    <category id="motor" name="{{ROBOTICS_CAT_MOTORS}}" colour="#0090f5" icon="undo">
      <label text="{{ROBOTICS_CAT_DC_MOTORS}}" web-class="blockLabelStyle"></label>
      <block type="robotics_motori2c_init" />
      <block type="robotics_motor_set_encoder">
        <value name="rpm">
          <shadow type="math_number">
            <field name="NUM">350</field>
          </shadow>
        </value>
        <value name="ppr">
          <shadow type="math_number">
            <field name="NUM">13</field>
          </shadow>
        </value>
        <value name="gears">
          <shadow type="math_number">
            <field name="NUM">48</field>
          </shadow>
        </value>
      </block>
      <block type="robotics_motor_run">
        <value name="speed">
          <shadow type="math_number">
            <field name="NUM">70</field>
          </shadow>
        </value>
      </block>
      <block type="robotics_motor_brake"></block>
      <block type="robotics_motor_run_wait">
        <value name="amount">
          <shadow type="math_number">
            <field name="NUM">1</field>
          </shadow>
        </value>
        <value name="speed">
          <shadow type="math_number">
            <field name="NUM">50</field>
          </shadow>
        </value>
      </block>

      <block type="robotics_motor_run_stalled">
        <value name="speed">
          <shadow type="math_number">
            <field name="NUM">50</field>
          </shadow>
        </value>
      </block>

      <block type="robotics_motor_get" />

      <block type="robotics_motor_reset_angle" />

      <sep gap="30"></sep>
      <label text="{{ROBOTICS_CAT_SERVO_MOTORS}}" web-class="blockLabelStyle"></label>
      <block type="robotics_servo_init" />
      <block type="robotics_servo_limit">
        <value name="min">
          <shadow type="math_number">
            <field name="NUM">0</field>
          </shadow>
        </value>
        <value name="max">
          <shadow type="math_number">
            <field name="NUM">180</field>
          </shadow>
        </value>
      </block>
      <block type="robotics_servo_angle">
        <value name="angle">
          <shadow type="math_number">
            <field name="NUM">180</field>
          </shadow>
        </value>
        <value name="speed">
          <shadow type="math_number">
            <field name="NUM">90</field>
          </shadow>
        </value>
      </block>
      <block type="robotics_servo_steps">
        <value name="steps">
          <shadow type="math_number">
            <field name="NUM">5</field>
          </shadow>
        </value>
      </block>
      <block type="robotics_servo_spin">
        <value name="speed">
          <shadow type="math_number">
            <field name="NUM">100</field>
          </shadow>
        </value>
      </block>
    </category>

    <category id="robotics-sensor" name="{{ROBOTICS_CAT_SENSOR}}" colour="#9b6af6" icon="vr-cardboard">
      <label text="{{ROBOTICS_CAT_ANGLE_SENSOR}}" web-class="blockLabelStyle"></label>
      <block type="robotics_angle_sensor_init">
        <value name="samples">
          <shadow type="math_number">
            <field name="NUM">250</field>
          </shadow>
        </value>
      </block>
      <block type="robotics_angle_sensor_calib">
        <value name="samples">
          <shadow type="math_number">
            <field name="NUM">250</field>
          </shadow>
        </value>
      </block>
      <block type="robotics_angle_sensor_get" />
      <block type="robotics_angle_sensor_get_imu" />
      <block type="robotics_angle_sensor_reset" />
      <block type="robotics_angle_sensor_config" />

      <label text="{{ROBOTICS_CAT_BAT_SENSOR}}" web-class="blockLabelStyle"></label>
      <block type="robotics_get_battery" />

    </category>

  </category>
</xml>
